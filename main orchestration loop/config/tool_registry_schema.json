{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["version", "tools"],
  "properties": {
    "version": {"type": "string"},
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "owner", "cursor_sdk_required", "phases_allowed", "description"],
        "properties": {
          "id": {"type": "string", "pattern": "^T[0-9]{2}$"},
          "owner": {"type": "string", "enum": ["PY", "HERMES", "CURSOR", "HYBRID"]},
          "cursor_sdk_required": {"type": "boolean"},
          "phases_allowed": {
            "type": "array",
            "items": {"type": "string", "enum": ["P0", "P1", "P2", "P3", "P4", "P5"]}
          },
          "description": {"type": "string"}
        }
      }
    }
  }
}

# Copy to .env.local and fill in your values (never commit .env.local)
CURSOR_API_KEY=crsr_your_key_here

# T09 runtime: auto (Cursor then Qwen), cursor, or qwen
HERMES_T09_RUNTIME=auto

# Cursor SDK: local (WSL2), cloud (GitHub remote), auto (local then cloud on WinError 10038)
HERMES_CURSOR_RUNTIME=local

# Set HERMES_CLOUD_PROBE=1 to run a live cloud spawn in verify_cursor_cloud.py
# HERMES_CLOUD_PROBE=0
